{
	email {$ACME_EMAIL}
}

# ── HeartBits web + API ────────────────────────────────────────────────────────
{$APP_DOMAIN} {
	encode gzip

	header {
		defer
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "DENY"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Permissions-Policy        "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# API — strip /api prefix before forwarding
	handle_path /api/* {
		reverse_proxy heartbits-api:3100
	}

	# SvelteKit app
	handle {
		reverse_proxy heartbits-web:3000
	}
}

# ── Zitadel auth ───────────────────────────────────────────────────────────────
{$AUTH_DOMAIN} {
	encode gzip

	# Next.js login UI (v2)
	handle /ui/v2/login/* {
		reverse_proxy login:3000
	}

	# Zitadel core (OIDC, JWKS, console, SAML)
	handle {
		reverse_proxy zitadel:8180 {
			transport http {
				versions h2c 2
			}
		}
	}
}

# ── WebSocket relay ────────────────────────────────────────────────────────────
{$RELAY_DOMAIN} {
	encode gzip

	header {
		defer
		X-Content-Type-Options "nosniff"
		X-Frame-Options        "DENY"
		Referrer-Policy        "strict-origin-when-cross-origin"
		-Server
	}

	reverse_proxy heartbits-relay:8765
}

# ── API subdomain ─────────────────────────────────────────────────────────────
{$API_DOMAIN} {
	encode gzip

	header {
		defer
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "strict-origin-when-cross-origin"
		-Server
		Access-Control-Allow-Origin  "*"
		Access-Control-Allow-Methods "GET, POST, PATCH, DELETE, OPTIONS"
		Access-Control-Allow-Headers "Authorization, Content-Type"
	}

	@options method OPTIONS
	respond @options 204

	reverse_proxy heartbits-api:3100
}

# ── Media / object storage (public avatar CDN) ────────────────────────────────
{$MEDIA_DOMAIN} {
	encode gzip

	header {
		defer
		Cache-Control              "public, max-age=31536000, immutable"
		Access-Control-Allow-Origin "*"
		X-Content-Type-Options     "nosniff"
		-Server
	}

	# Proxy to MinIO S3 API — bucket is public-read (policy set by API on startup)
	reverse_proxy minio:9000
}

# ── Status page subdomain ─────────────────────────────────────────────────────
{$STATUS_DOMAIN} {
	redir https://{$APP_DOMAIN}/status permanent
}

# ── Internal HTTP proxy on :8180 ───────────────────────────────────────────────
# Not exposed publicly (Caddy only publishes 80/443 externally).
# The login container calls http://${AUTH_DOMAIN}:8180 which resolves here via
# Docker DNS; Caddy forwards with the original Host header so Zitadel identifies
# the instance correctly.
:8180 {
	reverse_proxy zitadel:8180 {
		transport http {
			versions h2c 2
		}
	}
}
