# HeartBits deployment environment
# Copy to .env and fill in every value before running docker compose up -d
# Generate secrets:  openssl rand -hex 32

# ── Domains ───────────────────────────────────────────────────────────────────
APP_DOMAIN=heartbits.example.com
AUTH_DOMAIN=auth.heartbits.example.com
RELAY_DOMAIN=relay.heartbits.example.com
API_DOMAIN=api.heartbits.example.com
MEDIA_DOMAIN=media.heartbits.example.com
STATUS_DOMAIN=status.heartbits.example.com
ACME_EMAIL=admin@example.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=
# Worker role password — role must have BYPASSRLS (see migration notes in heartbits-api/.env.example)
WORKER_POSTGRES_PASSWORD=

# ── MinIO media storage ───────────────────────────────────────────────────────
MINIO_USER=heartbits
MINIO_PASSWORD=

# ── Zitadel ───────────────────────────────────────────────────────────────────
# Exactly 32 characters
ZITADEL_MASTERKEY=
ZITADEL_ADMIN_PASSWORD=

# ── HeartBits OIDC (filled by bootstrap.sh) ───────────────────────────────────
HEARTBITS_CLIENT_ID=
HEARTBITS_CLIENT_SECRET=

# ── Web app ───────────────────────────────────────────────────────────────────
# openssl rand -hex 32
SESSION_SECRET=
# Optional: set to enable a password wall before the app goes public
STAGING_PASSWORD=

# ── API ───────────────────────────────────────────────────────────────────────
# openssl rand -hex 32  (used to encrypt biometric fields at rest)
HB_FIELD_ENCRYPTION_KEY=

# ── Relay ─────────────────────────────────────────────────────────────────────
ROOM_TOKEN=

# ── Email / SMTP ───────────────────────────────────────────────────────────────
# Required for email verification, password reset, and MFA codes.
# Recommended providers: Resend (smtp.resend.com:587, user=resend),
#   Postmark (smtp.postmarkapp.com:587), Mailgun, AWS SES.
# Applied on first Zitadel init. To change post-deploy: Zitadel console → Instance Settings → SMTP.
SMTP_HOST=smtp.resend.com:587
SMTP_USER=resend
SMTP_PASSWORD=
SMTP_FROM=noreply@heartbits.example.com
SMTP_FROM_NAME=HeartBits
