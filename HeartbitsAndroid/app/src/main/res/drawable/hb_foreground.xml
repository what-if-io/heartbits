          L 27,64
          C 28,64 29,57 32,57
          C 35,57 36,64 37,64
          L 38,70
          L 43,32
          L 47,74
          C 49,69 52,64 56,64
          C 58,64 60,58 62,57
          C 64,56 66,64 69,64
          C 70,58 73,40 79,38
          C 84,36 84,50 84,54
          C 84,50 84,36 89,40
          C 95,44 100,60 101,65">
        <aapt:attr name="android:strokeColor">
