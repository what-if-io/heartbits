DATABASE_URL=postgres://heartbits_api:password@localhost:5432/heartbits
# Worker-only: use a role with BYPASSRLS for cross-user queries (cleanupStaleRelayRooms, gdprHardDelete)
# CREATE ROLE heartbits_worker LOGIN PASSWORD '...' BYPASSRLS;
# GRANT SELECT ON app.bonds, app.matches TO heartbits_worker;
# GRANT DELETE ON app.users TO heartbits_worker;
WORKER_DATABASE_URL=postgres://heartbits_worker:password@localhost:5432/heartbits
REDIS_URL=redis://localhost:6379
ZITADEL_ISSUER=https://auth.heartbits.example.com
ZITADEL_JWKS_URL=https://auth.heartbits.example.com/.well-known/openid-configuration
# Zitadel OIDC client ID for the heartbits-web app (used to validate JWT aud claim)
ZITADEL_CLIENT_ID=
# 64-char hex string — generate with: openssl rand -hex 32
HB_FIELD_ENCRYPTION_KEY=
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=heartbits
MINIO_SECRET_KEY=
MINIO_USE_SSL=false
MINIO_BUCKET=heartbits-media
# Public hostname for serving media (Caddy vhost → minio:9000)
MEDIA_DOMAIN=media.heartbits.example.com
PORT=3100
