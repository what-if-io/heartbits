DATABASE_URL=postgres://heartbits_api:password@localhost:5432/heartbits
REDIS_URL=redis://localhost:6379
ZITADEL_ISSUER=https://account.what-if.io
ZITADEL_JWKS_URL=https://account.what-if.io/.well-known/openid-configuration
# Zitadel OIDC client ID for the heartbits-web app (used to validate JWT aud claim)
ZITADEL_CLIENT_ID=
# 64-char hex string — generate with: openssl rand -hex 32
HB_FIELD_ENCRYPTION_KEY=
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=heartbits-media
PORT=3100
