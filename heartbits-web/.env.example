# heartbits-web environment
# Copy to .env.local and fill in. All vars are optional for demo mode —
# the app boots into an interactive demo when auth/API vars are unset.

# ── Public (exposed to the browser, must be prefixed PUBLIC_) ────────────────
# Zitadel OIDC issuer URL and the web app's client ID (PKCE, public client).
PUBLIC_ZITADEL_ISSUER=https://auth.heartbits.example.com
PUBLIC_ZITADEL_CLIENT_ID=

# ── Private (server-only) ───────────────────────────────────────────────────
# Public origin of this web app; used to build OIDC redirect/post-logout URIs.
ORIGIN=http://localhost:5173
# 32+ random bytes signing session cookies. REQUIRED for real (non-demo) auth.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
# Only for confidential OIDC clients. Omit for PKCE-only (the default).
ZITADEL_CLIENT_SECRET=
# If set, gates the whole app behind a shared password (staging). Leave unset locally.
STAGING_PASSWORD=

# ── Service URLs (server-side fetches) ──────────────────────────────────────
# Internal base URL of heartbits-api. Default targets the docker-compose service.
API_BASE_INTERNAL=http://localhost:3100
# WebSocket relay base URL (ws:// or wss://), used to mint bond connect URLs.
RELAY_URL=ws://localhost:8765
# heartbits-monitor base URL, read by the /status page.
MONITOR_URL=http://localhost:4000
# Public URLs used by /status for live health pings (optional).
WEB_URL=
AUTH_URL=
